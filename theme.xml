<theme>
  <view name="system"> 
    <image name="help-right-system">
      <pos>1 1</pos>
      <origin>1 1</origin>
      <size>${helpSize}</size>
      <path>${helpRightSystemPath}</path>
    </image>
  </view>

  <view name="gamelist">      
    <image name="help-right-games">
      <pos>1 1</pos>
      <origin>1 1</origin>
      <size>${helpSize}</size>
      <path>${helpRightGamesPath}</path>
    </image>
  </view>

    <view name="system">    
      <image name="help-left">
        <pos>0 1</pos>
        <origin>0 1</origin>
        <size>${helpSize}</size>
        <path>${helpLeftPath}</path>
      </image>
    </view>

    <variant name="boxart">
      <aspectRatio name="19.5:9, 16:9, 16:10">
          <view name="gamelist">
            <image name="game-cover">
              <pos>${boxartPosition}</pos>
              <origin>1 0.5</origin>
              <maxSize>0.3 0.733333333333333</maxSize>
              <cornerRadius>0.02</cornerRadius>
              <imageType>cover</imageType>
            </image>
          </view>
      </aspectRatio>
    </variant>

  <view name="system,gamelist">
    <textlist name="item-list">
      <origin>0 0</origin>
      <pos>${listPosition}</pos>
      <size>${textListSize}</size>

      <fontPath>./BPreplayBold-unhinted.otf</fontPath>
      <primaryColor>${foregroundColor}</primaryColor>
      <secondaryColor>${foregroundColor}</secondaryColor>
      <selectorColor>${transparentColor}</selectorColor>
      <selectedColor>${backgroundColor}</selectedColor>
      <selectedBackgroundColor>${foregroundColor}</selectedBackgroundColor>
      <indicators>ascii</indicators>

      <lineSpacing>1.875</lineSpacing>
      <fontSize>${listFontSize}</fontSize>

      <selectedBackgroundCornerRadius>0.5</selectedBackgroundCornerRadius>
      <selectedBackgroundMargins>${selectedMarginSize}</selectedBackgroundMargins>
      <selectorHeight>${selectorHeightSize}</selectorHeight>
    </textlist>

    <helpsystem name="help">
      <pos>2 2</pos>
      <textColor>${transparentColor}</textColor>
      <iconColor>${transparentColor}</iconColor>
    </helpsystem>
  </view>

  <aspectRatio name="19.5:9, 16:9, 16:10, 4:3">
    <view name="system,gamelist">
      <image name="help-left">
        <pos>0 1</pos>
        <origin>0 1</origin>
        <size>${helpSize}</size>
        <path>${helpLeftPath}</path>
      </image>
    </view>
  </aspectRatio>

  <variables>
    <transparentColor>00000000</transparentColor>
    <backgroundColor>000000FF</backgroundColor>
    <foregroundColor>F7FBF7FF</foregroundColor>

    <helpLeftPath>.</helpLeftPath>
    <helpRightSystemPath>.</helpRightSystemPath>
    <helpRightGamesPath>.</helpRightGamesPath>
    <textListSize>0.56 0.9</textListSize>

    <listFontSize>0.066666666666667</listFontSize>
    <helpSize>0 0.266666666666667</helpSize>
    <selectorHeightSize>0.12</selectorHeightSize>
    <selectedMarginSize>0.0285 0.0285</selectedMarginSize>
    <listLineSpacing>1.9</listLineSpacing>
    <listPosition>0.053 0.045</listPosition>
    <boxartPosition>0.964 0.5</boxartPosition>
  </variables>

  <colorScheme name="letter-prompts">
    <variables> 
      <helpLeftPath>./help-left.svg</helpLeftPath>
      <helpRightSystemPath>./help-right-system.svg</helpRightSystemPath>
      <helpRightGamesPath>./help-right-games.svg</helpRightGamesPath>

      <textListSize>0.56 0.8</textListSize>
      <boxartPosition>0.9645 0.43</boxartPosition>
    </variables>
  </colorScheme>

  <colorScheme name="symbol-prompts">
    <variables>
      <helpLeftPath>./help-left.svg</helpLeftPath>
      <helpRightSystemPath>./help-right-system-psx.svg</helpRightSystemPath>
      <helpRightGamesPath>./help-right-games-psx.svg</helpRightGamesPath>

      <textListSize>0.56 0.8</textListSize>
      <boxartPosition>0.964 0.43</boxartPosition>
    </variables>
  </colorScheme>

  <fontSize name="medium">
    <variables>
    <listFontSize>0.058333333333334</listFontSize>
      <helpSize>0 0.233333333333336</helpSize>
      <selectorHeightSize>0.105</selectorHeightSize>
      <selectedMarginSize>0.02499375 0.02499375</selectedMarginSize>
      <listLineSpacing>1.85</listLineSpacing>
      <listPosition>0.045218955 0.066666666666667</listPosition>
    </variables>
  </fontSize>

  <fontSize name="small">
    <variables>
      <listFontSize>0.05</listFontSize>
      <helpSize>0 0.2</helpSize>
      <selectorHeightSize>0.09</selectorHeightSize>
      <selectedMarginSize>0.021375 0.021375</selectedMarginSize>
      <listLineSpacing>1.8875</listLineSpacing>
      <listPosition>0.038671875 0.07407407</listPosition>
    </variables>
  </fontSize>

  <aspectRatio name="4:3">
      <variables>
          <selectedMarginSize>0.038 0.038</selectedMarginSize>
      </variables>

      <fontSize name="medium">
        <variables>
          <selectedMarginSize>0.033325 0.033325</selectedMarginSize>
        </variables>
      </fontSize>

      <fontSize name="small">
        <variables>
          <selectedMarginSize>0.0285 0.0285</selectedMarginSize>
        </variables>
      </fontSize>
  </aspectRatio>

  <view name="all">
    <sound name="systembrowse"><path>.</path></sound>
    <sound name="quicksysselect"><path>.</path></sound>
    <sound name="select"><path>.</path></sound>
    <sound name="back"><path>.</path></sound>
    <sound name="scroll"><path>.</path></sound>
    <sound name="favorite"><path>.</path></sound>
    <sound name="launch"><path>.</path></sound>
  </view>
</theme>